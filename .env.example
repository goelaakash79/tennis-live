WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO_NUMBER=
WHATSAPP_API_VERSION=v20.0

# API-Tennis only (required). Uses get_livescore, get_fixtures, and get_tournaments (tournament allowlist:
# Grand Slams, Masters 1000, Finals, Olympics, major Indian opens incl. doubles).
# https://api.api-tennis.com/tennis/?method=get_livescore
# https://api.api-tennis.com/tennis/?method=get_fixtures
# https://api.api-tennis.com/tennis/?method=get_tournaments
TENNIS_API_KEY=
# Defaults to https://api.api-tennis.com/tennis/ if unset
TENNIS_API_HOST=

# Optional: on-demand cache bust for match data. Call GET or POST /api/revalidate with
# Authorization: Bearer <REVALIDATE_SECRET> (or ?secret= over HTTPS only).
REVALIDATE_SECRET=
